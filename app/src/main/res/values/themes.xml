<resources>
    <style name="Theme.AutoCareLedger" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#F7F9F8</item>
        <item name="android:navigationBarColor">#F7F9F8</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Устанавливаем фон сплеш-скрина (премиальный темный slate) -->
        <item name="windowSplashScreenBackground">#0F172A</item>
        <!-- Иконка по центру -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Возврат к основной теме после загрузки -->
        <item name="postSplashScreenTheme">@style/Theme.AutoCareLedger</item>
    </style>
</resources>
